{
  "name": "fabric-model-readiness",
  "version": "0.1.0",
  "description": "Desktop app for Power BI semantic model AI readiness analysis",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "dev:electron": "tsx electron/dev.ts",
    "build": "tsc -p electron/tsconfig.json && vite build --config frontend/vite.config.ts",
    "build:electron": "npm run build && electron-builder",
    "preview": "vite preview --config frontend/vite.config.ts"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
